{
  "name": "claude-settings-ui",
  "productName": "Claude Settings",
  "version": "1.0.0",
  "description": "Web UI for editing Claude CLI ~/.claude/settings.json",
  "author": "Claude",
  "private": true,
  "main": "main.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "electron": "electron .",
    "electron-dev": "electron . --inspect=9222",
    "dist": "npm run build",
    "dist-all": "npm run build",
    "build": "node scripts/build.js"
  },
  "devDependencies": {
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1",
    "electron-packager": "^17.1.2"
  }
}
